    "Parse Trends": {"main": [[{"node": "Insert Trends", "type": "main", "index": 0}]]},
    "Cron - Comments (30m)": {"main": [[{"node": "Get Unreplied Comments", "type": "main", "index": 0}]]},
    "Get Unreplied Comments": {"main": [[{"node": "Groq - Generate Reply", "type": "main", "index": 0}]]},
    "Groq - Generate Reply": {"main": [[{"node": "Save Reply", "type": "main", "index": 0}]]}
  },
  "settings": {"executionOrder": "v1"},
  "active": true
