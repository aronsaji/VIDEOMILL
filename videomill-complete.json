    "FFmpeg Concat": {"main": [[{"node": "Upload to Supabase", "type": "main", "index": 0}]]},
    "Upload to Supabase": {"main": [[{"node": "Status: complete", "type": "main", "index": 0}]]},
    "Cron - Trends (6t)": {"main": [[{"node": "Groq - Generate Trends", "type": "main", "index": 0}]]},
