    "Status: recording": {"main": [[{"node": "Split Scenes", "type": "main", "index": 0}]]},
    "Split Scenes": {"main": [[{"node": "Loop Scenes", "type": "main", "index": 0}]]},
    "Loop Scenes": {"main": [[{"node": "Pixabay Search", "type": "main", "index": 0}], {"node": "Loop Exit", "type": "main", "index": 0}]]},
